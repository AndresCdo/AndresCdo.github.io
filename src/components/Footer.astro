---
const year = new Date().getFullYear();

const social = [
  { href: 'https://github.com/AndresCdo',                          label: 'GitHub',     icon: 'GH' },
  { href: 'https://www.linkedin.com/in/andres-caicedo-58888720a/', label: 'LinkedIn',   icon: 'LI' },
  { href: 'https://twitter.com/AndresCdo',                         label: 'Twitter / X', icon: 'TW' },
];
---

<footer class="site-footer">
  <div class="wrapper footer-inner">
    <div class="footer-brand">
      <span class="footer-logo" aria-hidden="true">&lt;AC/&gt;</span>
      <p>DevOps Engineer &amp; SysAdmin<br />Building reliable infrastructure.</p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/">Home</a>
      <a href="/projects/">Projects</a>
      <a href="/blog/">Blog</a>
      <a href="/about/">About</a>
      <a href="/contact/">Contact</a>
      <a href="/rss.xml">RSS</a>
    </nav>

    <div class="footer-social">
      {social.map(({ href, label, icon }) => (
        <a
          href={href}
          class="social-btn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={label}
          title={label}
        >
          {icon}
        </a>
      ))}
    </div>
  </div>

  <div class="wrapper footer-bottom">
    <p>© {year} Andres Caicedo — Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>, deployed on <a href="https://pages.github.com" target="_blank" rel="noopener noreferrer">GitHub Pages</a>.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-alt);
    padding-top: var(--space-12);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: var(--space-10);
    align-items: start;
    padding-bottom: var(--space-10);
  }

  .footer-brand p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
    line-height: 1.6;
  }

  .footer-logo {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-brand);
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-nav a {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    transition: color var(--transition);
  }
  .footer-nav a:hover { color: var(--color-brand); text-decoration: none; }

  .footer-social {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    font-size: var(--text-xs);
    font-weight: 700;
    font-family: var(--font-mono);
    background: var(--color-surface);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all var(--transition);
    text-decoration: none;
  }
  .social-btn:hover {
    background: var(--color-brand);
    color: white;
    border-color: var(--color-brand);
    text-decoration: none;
  }

  .footer-bottom {
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }
  .footer-bottom p {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin: 0;
  }
  .footer-bottom a { color: var(--color-text-muted); }
  .footer-bottom a:hover { color: var(--color-brand); }

  @media (max-width: 640px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
    .footer-brand { grid-column: 1 / -1; }

    .footer-social { flex-direction: row; }
  }
</style>
