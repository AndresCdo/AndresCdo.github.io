---
import BaseLayout from '../layouts/BaseLayout.astro';
import { featuredProjects, otherProjects } from '../data/projects';

const categories = [...new Set([...featuredProjects, ...otherProjects].map(p => p.category))];
const isExternalUrl = (url: string) => /^https?:\/\//.test(url);
const isContactSubjectUrl = (url: string) => url.startsWith('/contact/?subject=');
const projectPrimaryUrl = (project: { url: string; relatedRepos?: { url: string }[] }) =>
  project.relatedRepos?.[0]?.url ?? project.url;
---

<BaseLayout
  title="Projects"
  description="Projects and implementation notes by Andres Caicedo — focused on CI/CD pipelines, Linux operations, and automation with Python."
  schema={{
    '@type': 'CollectionPage',
    name: 'Projects',
    url: 'https://andrescdo.github.io/projects/',
    inLanguage: 'en',
    mainEntity: featuredProjects.slice(0, 3).map((project) => ({
      '@type': 'CreativeWork',
      name: project.title,
      description: project.description,
      url: projectPrimaryUrl(project),
      keywords: project.tech,
    })),
  }}
>
  <div class="wrapper page-content">
    <header class="page-header animate-on-scroll">
      <p class="page-label">Portfolio</p>
      <h1>Projects</h1>
      <p class="page-lead">
        A collection of projects and implementation notes based on real workflows and
        operational problems I work on in practice.
      </p>
      <div class="page-stats" aria-label="Project statistics">
        <div class="stat">
          <span class="stat__number">{featuredProjects.length + otherProjects.length}</span>
          <span class="stat__label">Total Projects</span>
        </div>
        <div class="stat">
          <span class="stat__number">{categories.length}</span>
          <span class="stat__label">Categories</span>
        </div>
        <div class="stat">
          <span class="stat__number">{featuredProjects.length}</span>
          <span class="stat__label">Featured</span>
        </div>
      </div>
    </header>

    <section aria-labelledby="featured-heading" class="animate-on-scroll">
      <div class="section-divider">
        <h2 id="featured-heading" class="projects-section-title">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          Featured
        </h2>
      </div>
      <div class="projects-grid">
        {featuredProjects.map((project, i) => (
          <article class="project-card project-card--featured animate-on-scroll" style={`--delay: ${i * 0.1}s`}>
            <div class="project-card__accent" aria-hidden="true"></div>
            <div class="project-card__header">
              <span class="project-card__category">{project.category}</span>
              <h3 class="project-card__title">
                <a
                  href={project.url}
                  target={isExternalUrl(project.url) ? '_blank' : undefined}
                  rel={isExternalUrl(project.url) ? 'noopener noreferrer' : undefined}
                >
                  {project.title}
                  {isExternalUrl(project.url) && (
                    <>
                      <span class="external-link-indicator" aria-hidden="true">↗</span>
                      <span class="sr-only"> (opens in new tab)</span>
                    </>
                  )}
                </a>
              </h3>
            </div>
            <p class="project-card__description">{project.description}</p>
            <footer class="project-card__footer">
              <ul class="tech-stack" aria-label="Technologies used">
                {project.tech.map(t => <li class="tech-badge">{t}</li>)}
              </ul>
              <a
                class="btn btn--outline btn--sm"
                href={project.url}
                target={isExternalUrl(project.url) ? '_blank' : undefined}
                rel={isExternalUrl(project.url) ? 'noopener noreferrer' : undefined}
                aria-label={isExternalUrl(project.url) ? `View ${project.title} (opens in new tab)` : `View ${project.title}`}
              >
                {isContactSubjectUrl(project.url) ? 'Discuss project' : 'View project'}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
              </a>

              {project.relatedRepos?.length ? (
                <div class="project-card__repos" aria-label="Related repositories">
                  <span class="project-card__repos-label">Related repositories</span>
                  <ul class="project-card__repos-list" role="list">
                    {project.relatedRepos.map((repo) => (
                      <li>
                        <a
                          href={repo.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          aria-label={`Open ${repo.name} repository (opens in new tab)`}
                        >
                          {repo.name}
                          <span class="external-link-indicator" aria-hidden="true">↗</span>
                          <span class="sr-only"> (opens in new tab)</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ) : null}
            </footer>
          </article>
        ))}
      </div>
    </section>

    <section aria-labelledby="more-heading" class="more-projects animate-on-scroll">
      <div class="section-divider">
        <h2 id="more-heading" class="projects-section-title">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          More Projects
        </h2>
      </div>
      <div class="projects-grid">
        {otherProjects.map((project, i) => (
          <article class="project-card animate-on-scroll" style={`--delay: ${i * 0.1}s`}>
            <div class="project-card__header">
              <span class="project-card__category">{project.category}</span>
              <h3 class="project-card__title">
                <a
                  href={project.url}
                  target={isExternalUrl(project.url) ? '_blank' : undefined}
                  rel={isExternalUrl(project.url) ? 'noopener noreferrer' : undefined}
                >
                  {project.title}
                  {isExternalUrl(project.url) && (
                    <>
                      <span class="external-link-indicator" aria-hidden="true">↗</span>
                      <span class="sr-only"> (opens in new tab)</span>
                    </>
                  )}
                </a>
              </h3>
            </div>
            <p class="project-card__description">{project.description}</p>
            <footer class="project-card__footer">
              <ul class="tech-stack" aria-label="Technologies used">
                {project.tech.map(t => <li class="tech-badge">{t}</li>)}
              </ul>
              <a
                class="btn btn--outline btn--sm"
                href={project.url}
                target={isExternalUrl(project.url) ? '_blank' : undefined}
                rel={isExternalUrl(project.url) ? 'noopener noreferrer' : undefined}
                aria-label={isExternalUrl(project.url) ? `View ${project.title} (opens in new tab)` : `View ${project.title}`}
              >
                {isContactSubjectUrl(project.url) ? 'Discuss project' : 'View project'}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
              </a>

              {project.relatedRepos?.length ? (
                <div class="project-card__repos" aria-label="Related repositories">
                  <span class="project-card__repos-label">Related repositories</span>
                  <ul class="project-card__repos-list" role="list">
                    {project.relatedRepos.map((repo) => (
                      <li>
                        <a
                          href={repo.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          aria-label={`Open ${repo.name} repository (opens in new tab)`}
                        >
                          {repo.name}
                          <span class="external-link-indicator" aria-hidden="true">↗</span>
                          <span class="sr-only"> (opens in new tab)</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ) : null}
            </footer>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page-content { padding-block: var(--space-16); }

  .page-label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-brand);
    margin-bottom: var(--space-3);
  }

  .page-header {
    margin-bottom: var(--space-12);
  }
  .page-header h1 {
    margin-bottom: var(--space-4);
  }
  .page-lead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 60ch;
    line-height: var(--leading-normal);
  }

  .page-stats {
    display: flex;
    gap: var(--space-8);
    margin-top: var(--space-8);
    padding: var(--space-6);
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .stat__number {
    font-size: var(--text-3xl);
    font-weight: 800;
    color: var(--color-brand);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .stat__label {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .section-divider {
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-2);
  }

  .projects-section-title {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .more-projects {
    margin-top: var(--space-16);
  }

  /* Featured card accent */
  .project-card--featured {
    border-color: var(--color-brand-alpha);
  }
  .project-card__accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient-brand);
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  }

  @media (max-width: 640px) {
    .page-stats {
      flex-direction: row;
      gap: var(--space-6);
    }
  }
</style>
