---
import BaseLayout from '../layouts/BaseLayout.astro';
import { skills } from '../data/skills';

const experience = [
  { period: 'Current', title: 'DevOps & Platform Engineer', desc: 'Building and improving CI/CD pipelines, managing Linux infrastructure, and automating workflows.' },
  { period: 'Ongoing', title: 'Open Source Contributor', desc: 'Contributing to DevOps and automation tools, sharing knowledge through blog posts and code.' },
  { period: 'Foundation', title: 'Systems & Linux Administration', desc: 'Day-to-day Linux operations, server maintenance, networking, and security fundamentals.' },
];
---

<BaseLayout
  title="About — Andres Caicedo | DevOps & Platform Engineer"
  description="Andres Caicedo is a DevOps and Platform Engineer focused on CI/CD pipelines, Linux operations, and automation with Python."
  schema={{
    '@type': 'AboutPage',
    name: 'About Andres Caicedo',
    url: 'https://andrescdo.github.io/about/',
    inLanguage: 'en',
    mainEntity: {
      '@type': 'Person',
      name: 'Andres Caicedo',
      jobTitle: 'DevOps & Platform Engineer',
      description:
        'DevOps and Platform Engineer focused on CI/CD pipelines, Linux operations, and Python automation.',
    },
  }}
>
  <div class="wrapper page-content">

    <!-- Hero -->
    <section class="about-hero animate-on-scroll">
      <div class="about-hero-content">
        <div class="about-avatar" aria-hidden="true">
          <div class="about-avatar__ring"></div>
          <div class="about-avatar__inner">
            <svg width="48" height="48" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="32" height="32" rx="8" fill="url(#about-logo-gradient)"/>
              <path d="M8 22L14 10H18L24 22" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M10.5 18H21.5" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                <defs>
                  <linearGradient id="about-logo-gradient" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#5b5ce2"/>
                    <stop offset="0.5" stop-color="#06b6d4"/>
                    <stop offset="1" stop-color="#8b5cf6"/>
                  </linearGradient>
                </defs>
            </svg>
          </div>
        </div>
        <div class="about-hero-text">
          <p class="about-label">About Me</p>
          <h1>Hi, I'm <span class="gradient-text">Andres Caicedo</span></h1>
          <p class="about-tagline">DevOps & Platform Engineer</p>
          <p class="about-bio">
            I work on the practical side of DevOps: helping teams ship changes safely and consistently.
            My strongest areas are CI/CD pipeline design, Linux operations, and automation with Python
            and Bash to reduce manual work.
          </p>
          <div class="about-cta">
            <a class="btn btn--primary" href="/projects/">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
              See My Projects
            </a>
            <a class="btn btn--outline" href="/contact/">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              Get in Touch
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- What I do -->
    <section class="about-section animate-on-scroll">
      <div class="about-section__header">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <h2>What I Do</h2>
      </div>
      <div class="about-cards">
        <div class="about-card">
          <div class="about-card__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h3>CI/CD Pipelines</h3>
          <p>Build and improve release workflows for safe, consistent delivery across environments.</p>
        </div>
        <div class="about-card">
          <div class="about-card__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3>Linux Operations</h3>
          <p>Maintain and optimize Linux-based systems that development teams depend on daily.</p>
        </div>
        <div class="about-card">
          <div class="about-card__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h3>Automation & Tooling</h3>
          <p>Automate repetitive operational tasks with Python and Bash to reduce manual work.</p>
        </div>
      </div>
    </section>

    <!-- Journey -->
    <section class="about-section animate-on-scroll">
      <div class="about-section__header">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        <h2>Journey</h2>
      </div>
      <div class="timeline">
        {experience.map((exp, i) => (
          <div class="timeline-item animate-on-scroll" style={`--delay: ${i * 0.15}s`}>
            <div class="timeline-dot" aria-hidden="true"></div>
            <div class="timeline-content">
              <span class="timeline-period">{exp.period}</span>
              <h3 class="timeline-title">{exp.title}</h3>
              <p class="timeline-desc">{exp.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Skills grid -->
    <section class="about-section animate-on-scroll">
      <div class="about-section__header">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <h2>Skills & Technologies</h2>
      </div>
      <div class="skills-grid">
        {skills.map((group, i) => (
          <div class="skill-group animate-on-scroll" style={`--delay: ${i * 0.08}s`}>
            <h3 class="skill-group-title">
              <span class="skill-group-icon" aria-hidden="true">{group.icon}</span>
              {group.category}
            </h3>
            <ul class="tech-stack">
              {group.items.map(item => <li class="tech-badge">{item}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Connect -->
    <section class="about-section animate-on-scroll">
      <div class="about-section__header">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        <h2>Connect</h2>
      </div>
      <div class="connect-grid">
        <a href="https://github.com/AndresCdo" target="_blank" rel="noopener noreferrer" class="connect-card" aria-label="GitHub profile (opens in new tab)">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
          <div>
            <p class="connect-card__label">GitHub</p>
            <p class="connect-card__handle">github.com/AndresCdo</p>
          </div>
          <svg class="connect-card__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/andres-caicedo-58888720a/" target="_blank" rel="noopener noreferrer" class="connect-card" aria-label="LinkedIn profile (opens in new tab)">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          <div>
            <p class="connect-card__label">LinkedIn</p>
            <p class="connect-card__handle">andres-caicedo</p>
          </div>
          <svg class="connect-card__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </a>
        <a href="https://twitter.com/AndresCdo" target="_blank" rel="noopener noreferrer" class="connect-card" aria-label="Twitter profile (opens in new tab)">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4l11.733 16h4.267l-11.733 -16h-4.267zm6.4 0l9.6 16m-16 -16l9.6 16"/></svg>
          <div>
            <p class="connect-card__label">Twitter / X</p>
            <p class="connect-card__handle">@AndresCdo</p>
          </div>
          <svg class="connect-card__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </a>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .page-content { padding-block: var(--space-16); }

  .about-label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-brand);
    margin-bottom: var(--space-3);
  }

  /* ── Hero ── */
  .about-hero {
    margin-bottom: var(--space-16);
    padding-bottom: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .about-hero-content {
    display: flex;
    gap: var(--space-10);
    align-items: flex-start;
  }

  .about-avatar {
    flex-shrink: 0;
    position: relative;
  }
  .about-avatar__ring {
    position: absolute;
    inset: -6px;
    border-radius: var(--radius-2xl);
    background: var(--gradient-brand);
    opacity: 0.3;
    animation: pulse-glow 3s ease infinite;
  }
  .about-avatar__inner {
    position: relative;
    width: 80px;
    height: 80px;
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-hero h1 {
    margin-bottom: var(--space-2);
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
  }

  .about-tagline {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-brand);
    margin-bottom: var(--space-5);
  }

  .about-bio {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 60ch;
    line-height: var(--leading-normal);
    margin-bottom: var(--space-8);
  }

  .about-cta {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* ── Sections ── */
  .about-section {
    margin-bottom: var(--space-16);
  }

  .about-section__header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }
  .about-section__header h2 {
    margin: 0;
  }

  /* ── What I Do cards ── */
  .about-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-6);
  }

  .about-card {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    transition:
      border-color var(--transition),
      box-shadow var(--transition-slow),
      transform var(--transition-fast);
  }
  .about-card:hover {
    border-color: var(--color-brand);
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }

  .about-card__icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg);
    background: var(--color-brand-light);
    color: var(--color-brand);
    margin-bottom: var(--space-4);
  }

  .about-card h3 {
    font-size: var(--text-base);
    margin-bottom: var(--space-2);
  }

  .about-card p {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* ── Timeline ── */
  .timeline {
    position: relative;
    padding-left: var(--space-8);
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 4px;
    bottom: 4px;
    width: 2px;
    background: var(--gradient-brand);
    border-radius: var(--radius-full);
    opacity: 0.3;
  }

  .timeline-item {
    position: relative;
    padding-bottom: var(--space-8);
  }
  .timeline-item:last-child { padding-bottom: 0; }

  .timeline-dot {
    position: absolute;
    left: calc(-1 * var(--space-8) + 3px);
    top: 4px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-brand);
    border: 2px solid var(--color-bg);
    box-shadow: 0 0 0 3px var(--color-brand-alpha);
  }

  .timeline-period {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand);
    margin-bottom: var(--space-1);
    display: block;
  }

  .timeline-title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }

  .timeline-desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    max-width: 55ch;
    margin: 0;
  }

  /* ── Skills ── */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-5);
  }

  .skill-group {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-5);
    transition: border-color var(--transition), box-shadow var(--transition);
  }
  .skill-group:hover {
    border-color: var(--color-brand-alpha);
    box-shadow: var(--shadow-md);
  }

  .skill-group-title {
    font-size: var(--text-sm);
    font-weight: 600;
    margin-bottom: var(--space-4);
    color: var(--color-heading);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .skill-group-icon {
    font-size: 1.1rem;
  }

  /* ── Connect ── */
  .connect-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  .connect-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    color: var(--color-text);
    transition:
      border-color var(--transition),
      box-shadow var(--transition),
      transform var(--transition-fast),
      color var(--transition);
  }
  .connect-card:hover {
    border-color: var(--color-brand);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
    color: var(--color-heading);
  }

  .connect-card svg:first-child {
    flex-shrink: 0;
    color: var(--color-brand);
  }

  .connect-card__label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 2px;
  }
  .connect-card__handle {
    font-size: var(--text-base);
    font-weight: 500;
    margin: 0;
  }

  .connect-card__arrow {
    margin-left: auto;
    color: var(--color-text-muted);
    transition: color var(--transition), transform var(--transition-fast);
    flex-shrink: 0;
  }
  .connect-card:hover .connect-card__arrow {
    color: var(--color-brand);
    transform: translate(2px, -2px);
  }

  @media (max-width: 768px) {
    .about-hero-content {
      flex-direction: column;
      gap: var(--space-6);
    }
  }
</style>
