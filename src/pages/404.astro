---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Page Not Found"
  description="The page you're looking for doesn't exist. Let's get you back on track."
  noindex={true}
>
  <div class="wrapper">
    <div class="not-found">
      <!-- Animated orbs -->
      <div class="not-found-bg" aria-hidden="true">
        <div class="nf-orb nf-orb--1"></div>
        <div class="nf-orb nf-orb--2"></div>
      </div>

      <p class="error-code" aria-hidden="true">
        <span class="error-digit">4</span>
        <span class="error-digit error-digit--middle">0</span>
        <span class="error-digit">4</span>
      </p>

      <h1 class="error-heading">Page Not Found</h1>
      <p class="error-message">
        Looks like this pipeline failed — the page you're looking for doesn't exist,
        was moved, or has been decommissioned.
      </p>

      <!-- Terminal-style error -->
      <div class="error-terminal" aria-hidden="true">
        <div class="error-terminal__bar">
          <span class="dot dot--red"></span>
          <span class="dot dot--yellow"></span>
          <span class="dot dot--green"></span>
        </div>
        <div class="error-terminal__body">
          <code>
            <span class="t-prompt">$</span> <span class="t-cmd">curl</span> <span class="t-flag">{Astro.url.pathname}</span><br/>
            <span class="t-error">Error 404: resource not found</span><br/>
            <span class="t-prompt">$</span> <span class="t-cmd">echo</span> <span class="t-string">"Let's find a working route..."</span><br/>
            <span class="t-cursor">_</span>
          </code>
        </div>
      </div>

      <nav class="error-nav" aria-label="Recovery navigation">
        <a class="btn btn--primary btn--lg" href="/">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Back to Home
        </a>
        <a class="btn btn--outline btn--lg" href="/blog/">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          Read the Blog
        </a>
        <a class="btn btn--outline btn--lg" href="/projects/">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          View Projects
        </a>
      </nav>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-block: var(--space-20);
    min-height: 70vh;
    position: relative;
    overflow: hidden;
  }

  .not-found-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .nf-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.3;
  }
  .nf-orb--1 {
    width: 400px;
    height: 400px;
    background: var(--color-brand);
    top: -20%;
    right: -10%;
    animation: float 8s ease-in-out infinite;
  }
  .nf-orb--2 {
    width: 300px;
    height: 300px;
    background: var(--color-accent-2);
    bottom: -20%;
    left: -10%;
    animation: float 10s ease-in-out infinite reverse;
  }

  .error-code {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    animation: fadeInDown 0.6s ease both;
  }

  .error-digit {
    font-size: clamp(5rem, 18vw, 9rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.04em;
    background: var(--gradient-brand);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 4s ease infinite;
  }
  .error-digit--middle {
    animation-delay: 0.5s;
  }

  .error-heading {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-5);
    animation: fadeInUp 0.6s ease 0.2s both;
  }

  .error-message {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 48ch;
    line-height: var(--leading-normal);
    margin-bottom: var(--space-8);
    animation: fadeInUp 0.6s ease 0.3s both;
  }

  /* Terminal */
  .error-terminal {
    max-width: 480px;
    width: 100%;
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    margin-bottom: var(--space-10);
    text-align: left;
    box-shadow: var(--shadow-xl);
    animation: scaleIn 0.6s ease 0.4s both;
  }

  .error-terminal__bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot--red    { background: #ff5f57; }
  .dot--yellow { background: #febc2e; }
  .dot--green  { background: #28c840; }

  .error-terminal__body {
    padding: var(--space-5);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.9;
  }

  .t-prompt { color: var(--color-success); font-weight: 600; }
  .t-cmd    { color: var(--color-brand); font-weight: 600; }
  .t-flag   { color: var(--color-accent); }
  .t-string { color: var(--color-warning); }
  .t-error  { color: var(--color-error); font-weight: 500; }
  .t-cursor {
    color: var(--color-brand);
    animation: typing-cursor 1s ease infinite;
  }

  .error-nav {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
    animation: fadeInUp 0.6s ease 0.6s both;
  }

  @media (max-width: 640px) {
    .error-nav {
      flex-direction: column;
      width: 100%;
      max-width: 300px;
    }
  }
</style>
