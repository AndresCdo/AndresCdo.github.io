---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Group by year
const byYear = allPosts.reduce<Record<string, typeof allPosts>>((acc, post) => {
  const year = post.data.date.getFullYear().toString();
  (acc[year] ??= []).push(post);
  return acc;
}, {});

const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout
  title="Blog"
  description="Articles, tutorials, and insights on DevOps, SysAdmin, Kubernetes, CI/CD, and cloud engineering by Andres Caicedo."
>
  <div class="wrapper page-content">
    <header class="page-header">
      <h1>Blog</h1>
      <p class="page-lead">
        {allPosts.length} article{allPosts.length !== 1 ? 's' : ''} — DevOps, SRE, infrastructure, and open-source.
      </p>
    </header>

    {allPosts.length > 0 ? (
      years.map(year => (
        <div class="archive-year">
          <h2 class="archive-year-heading">{year}</h2>
          <ul class="archive-list">
            {byYear[year]!.map(post => (
              <li class="archive-item">
                <time class="archive-date" datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                </time>
                <a class="archive-link" href={`/blog/${post.slug}/`}>
                  {post.data.title}
                </a>
                {(post.data.categories ?? []).length > 0 && (
                  <span class="archive-tags">
                    {(post.data.categories as string[]).map((c: string) => (
                      <span class="tag">{c}</span>
                    ))}
                  </span>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))
    ) : (
      <p class="empty-state">No posts yet — <a href="/rss.xml">subscribe via RSS</a> to be notified.</p>
    )}
  </div>
</BaseLayout>

<style>
  .page-content { padding-block: var(--space-16); }

  .page-header { margin-bottom: var(--space-12); }
  .page-lead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-top: var(--space-4);
  }

  .archive-year { margin-bottom: var(--space-10); }

  .archive-year-heading {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-4);
  }

  .archive-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .archive-item {
    display: grid;
    grid-template-columns: 6rem 1fr auto;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .archive-item:last-child { border-bottom: none; }

  .archive-date {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .archive-link {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-heading);
    transition: color var(--transition);
  }
  .archive-link:hover { color: var(--color-brand); text-decoration: none; }

  .archive-tags {
    display: flex;
    gap: var(--space-1);
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  @media (max-width: 640px) {
    .archive-item {
      grid-template-columns: 5rem 1fr;
    }
    .archive-tags { display: none; }
  }
</style>
