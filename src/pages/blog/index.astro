---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Group by year
const byYear = allPosts.reduce<Record<string, typeof allPosts>>((acc, post) => {
  const year = post.data.date.getFullYear().toString();
  (acc[year] ??= []).push(post);
  return acc;
}, {});

const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout
  title="Blog"
  description="Practical notes on CI/CD pipelines, Linux operations, and Python automation by Andres Caicedo."
  schema={{
    '@type': 'Blog',
    name: 'Andres Caicedo Blog',
    url: 'https://andrescdo.github.io/blog/',
    inLanguage: 'en',
    blogPost: allPosts.slice(0, 10).map((post) => ({
      '@type': 'BlogPosting',
      headline: post.data.title,
      datePublished: post.data.date.toISOString(),
      url: `https://andrescdo.github.io/blog/${post.slug}/`,
      description: post.data.description,
    })),
  }}
>
  <div class="wrapper page-content">
    <header class="page-header animate-on-scroll">
      <p class="page-label">Writing</p>
      <h1>Blog</h1>
      <p class="page-lead">
        {allPosts.length} article{allPosts.length !== 1 ? 's' : ''} — CI/CD, Linux operations, automation, and case studies.
      </p>
      <a href="/rss.xml" class="rss-badge" aria-label="Subscribe via RSS">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
        Subscribe via RSS
      </a>
    </header>

    {allPosts.length > 0 ? (
      years.map((year, yi) => (
        <div class="archive-year animate-on-scroll" style={`--delay: ${yi * 0.1}s`}>
          <h2 class="archive-year-heading">
            <span class="archive-year-text">{year}</span>
            <span class="archive-year-count">{byYear[year]!.length} post{byYear[year]!.length !== 1 ? 's' : ''}</span>
          </h2>
          <ul class="archive-list">
            {byYear[year]!.map(post => (
              <li class="archive-item">
                <time class="archive-date" datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                </time>
                <a class="archive-link" href={`/blog/${post.slug}/`}>
                  {post.data.title}
                </a>
                {(post.data.categories ?? []).length > 0 && (
                  <span class="archive-tags">
                    {(post.data.categories as string[]).map((c: string) => (
                      <span class="tag">{c}</span>
                    ))}
                  </span>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))
    ) : (
      <div class="empty-state animate-on-scroll">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        <p class="empty-state__title">No posts yet</p>
        <p>Blog posts coming soon — <a href="/rss.xml">subscribe via RSS</a> to be notified.</p>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .page-content { padding-block: var(--space-16); }

  .page-label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-brand);
    margin-bottom: var(--space-3);
  }

  .page-header { margin-bottom: var(--space-12); }
  .page-lead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-top: var(--space-4);
    margin-bottom: var(--space-5);
  }

  .rss-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-brand);
    background: var(--color-brand-light);
    border-radius: var(--radius-full);
    transition:
      background-color var(--transition),
      color var(--transition),
      transform var(--transition-fast),
      box-shadow var(--transition);
  }
  .rss-badge:hover {
    background: var(--color-brand);
    color: var(--color-on-brand);
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: var(--shadow-brand);
  }

  .archive-year { margin-bottom: var(--space-10); }

  .archive-year-heading {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-4);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .archive-year-count {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    opacity: 0.6;
    letter-spacing: normal;
    text-transform: none;
  }

  .archive-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .archive-item {
    display: grid;
    grid-template-columns: 6rem 1fr auto;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    transition: background var(--transition);
    margin: 0 calc(-1 * var(--space-4));
  }
  .archive-item:hover {
    background: var(--color-surface);
  }

  .archive-date {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .archive-link {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-heading);
    transition: color var(--transition);
  }
  .archive-link:hover { color: var(--color-brand); text-decoration: none; }

  .archive-tags {
    display: flex;
    gap: var(--space-1);
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  /* Empty state */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-16);
    text-align: center;
    background: var(--gradient-card);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-xl);
  }
  .empty-state__title {
    font-weight: 700;
    font-size: var(--text-xl);
    color: var(--color-heading);
    margin: 0;
  }
  .empty-state p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  @media (max-width: 640px) {
    .archive-item {
      grid-template-columns: 5rem 1fr;
    }
    .archive-tags { display: none; }
  }
</style>
