---
import BaseLayout from '../layouts/BaseLayout.astro';
import { featuredProjects } from '../data/projects';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const coreStack = ['Kubernetes', 'Terraform', 'GCP', 'Ansible', 'Docker', 'GitHub Actions', 'Prometheus', 'Python'];
---

<BaseLayout
  title="Andres Caicedo — DevOps Engineer & SysAdmin"
  description="Personal site and blog of Andres Caicedo — DevOps Engineer specialising in Kubernetes, GCP, Terraform, and CI/CD automation."
>

  <!-- ── Hero ─────────────────────────────────────────────────────────────── -->
  <section class="hero" aria-label="Introduction">
    <div class="wrapper hero-inner">
      <div class="hero-text">
        <p class="hero-greeting">Hey there, I'm</p>
        <h1 class="hero-name">Andres Caicedo</h1>
        <p class="hero-tagline">DevOps Engineer &amp; SysAdmin</p>
        <p class="hero-description">
          I build and automate cloud infrastructure, design CI/CD pipelines, and write about
          DevOps, SRE, and open-source tooling. I care about eliminating toil through automation.
        </p>
        <div class="hero-actions">
          <a class="btn btn--primary" href="/projects/">View Projects</a>
          <a class="btn btn--outline" href="/blog/">Read the Blog</a>
        </div>
      </div>
      <div class="hero-badge" aria-hidden="true">
        <span class="hero-badge-inner">&lt;DevOps<br/>Engineer/&gt;</span>
      </div>
    </div>
  </section>

  <!-- ── Core stack strip ──────────────────────────────────────────────────── -->
  <section class="stack-strip" aria-label="Core technologies">
    <div class="wrapper stack-strip-inner">
      <span class="stack-strip-label">Core Stack</span>
      <ul role="list" class="stack-list">
        {coreStack.map(s => <li class="tech-badge">{s}</li>)}
      </ul>
    </div>
  </section>

  <!-- ── Featured Projects ─────────────────────────────────────────────────── -->
  <section class="home-section" aria-labelledby="projects-heading">
    <div class="wrapper">
      <header class="section-header">
        <h2 id="projects-heading" class="section-header__title">Featured Projects</h2>
        <a class="section-header__link" href="/projects/">All projects →</a>
      </header>

      <div class="projects-grid">
        {featuredProjects.map(project => (
          <article class="project-card">
            <div class="project-card__header">
              <span class="project-card__category">{project.category}</span>
              <h3 class="project-card__title">
                <a href={project.url} target="_blank" rel="noopener noreferrer">
                  {project.title}
                </a>
              </h3>
            </div>
            <p class="project-card__description">{project.description}</p>
            <footer class="project-card__footer">
              <ul class="tech-stack">
                {project.tech.slice(0, 4).map(t => <li class="tech-badge">{t}</li>)}
              </ul>
              <a class="btn btn--outline btn--sm"
                 href={project.url}
                 target="_blank"
                 rel="noopener noreferrer">
                GitHub →
              </a>
            </footer>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Latest Posts ──────────────────────────────────────────────────────── -->
  <section class="home-section home-section--alt" aria-labelledby="posts-heading">
    <div class="wrapper">
      <header class="section-header">
        <h2 id="posts-heading" class="section-header__title">Latest Posts</h2>
        <a class="section-header__link" href="/blog/">All posts →</a>
      </header>

      {posts.length > 0 ? (
        <ul class="post-list">
          {posts.map(post => (
            <li class="post-item">
              <div class="post-item__meta">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
                {(post.data.categories ?? []).map((c: string) => <span class="tag">{c}</span>)}
              </div>
              <h3 class="post-item__title">
                <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
              </h3>
              <p class="post-item__excerpt">{post.data.description}</p>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty-state">Blog posts coming soon — <a href="/rss.xml">subscribe via RSS</a> to stay updated.</p>
      )}
    </div>
  </section>

  <!-- ── Newsletter CTA ────────────────────────────────────────────────────── -->
  <section class="home-section home-section--cta" aria-labelledby="cta-heading">
    <div class="wrapper cta-block">
      <h2 id="cta-heading">Stay in the loop</h2>
      <p>Get notified about new posts and projects. No spam, unsubscribe anytime.</p>
      <form
        class="newsletter-form"
        action="https://formspree.io/f/xvzwwjeo"
        method="POST"
        aria-label="Newsletter signup"
      >
        <div class="newsletter-form-row">
          <label for="newsletter-email" class="sr-only">Email address</label>
          <input
            type="email"
            id="newsletter-email"
            name="email"
            placeholder="your@email.com"
            required
            autocomplete="email"
            aria-required="true"
          />
          <button type="submit" class="btn btn--primary">Subscribe</button>
        </div>
        <input type="hidden" name="_subject" value="New newsletter subscriber" />
        <input type="text"   name="_gotcha"  style="display:none" tabindex="-1" autocomplete="off" />
      </form>
      <p class="rss-hint">
        Or <a href="/rss.xml">subscribe via RSS ↗</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-20) 0 var(--space-16);
    background: radial-gradient(ellipse at 70% 50%, color-mix(in srgb, var(--color-brand) 8%, transparent) 0%, transparent 60%);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-12);
    align-items: center;
  }

  .hero-greeting {
    font-size: var(--text-lg);
    color: var(--color-brand);
    font-weight: 500;
    margin-bottom: var(--space-2);
  }

  .hero-name {
    font-size: clamp(var(--text-3xl), 6vw, var(--text-5xl));
    margin-bottom: var(--space-2);
    background: linear-gradient(135deg, var(--color-heading) 40%, var(--color-brand));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-tagline {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 52ch;
    line-height: var(--leading-normal);
    margin-bottom: var(--space-8);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hero-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 180px;
    height: 180px;
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .hero-badge-inner {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-brand);
    text-align: center;
    line-height: 1.8;
  }

  /* ── Stack strip ── */
  .stack-strip {
    padding: var(--space-6) 0;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .stack-strip-inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .stack-strip-label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .stack-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* ── CTA block ── */
  .cta-block {
    text-align: center;
    padding-block: var(--space-16);
  }
  .cta-block h2 { margin-bottom: var(--space-4); }
  .cta-block p  { margin-bottom: var(--space-8); opacity: 0.9; }

  .newsletter-form-row {
    display: flex;
    gap: var(--space-3);
    max-width: 420px;
    margin: 0 auto var(--space-4);
  }

  .newsletter-form-row input {
    flex: 1;
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-base);
    font-family: var(--font-sans);
    background: rgba(255,255,255,0.15);
    color: white;
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: var(--radius-md);
    outline: none;
  }
  .newsletter-form-row input::placeholder { color: rgba(255,255,255,0.6); }
  .newsletter-form-row input:focus {
    border-color: white;
    background: rgba(255,255,255,0.25);
  }
  .newsletter-form-row .btn--primary {
    background: white;
    color: var(--color-brand);
    border-color: white;
    flex-shrink: 0;
  }
  .newsletter-form-row .btn--primary:hover {
    background: rgba(255,255,255,0.9);
  }

  .rss-hint {
    font-size: var(--text-sm);
    opacity: 0.8;
    margin: 0;
  }
  .rss-hint a { color: white; text-decoration: underline; }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-badge { display: none; }

    .newsletter-form-row {
      flex-direction: column;
    }
  }
</style>
