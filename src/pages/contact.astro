---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Andres Caicedo about DevOps, CI/CD, Linux operations, or collaboration opportunities."
  schema={{
    '@type': 'ContactPage',
    name: 'Contact Andres Caicedo',
    url: 'https://andrescdo.github.io/contact/',
    inLanguage: 'en',
  }}
>
  <div class="wrapper page-content">

    <header class="page-header animate-on-scroll">
      <p class="page-label">Contact</p>
      <h1>Get in Touch</h1>
      <p class="page-subtitle">
        Have a project in mind, a question about DevOps, or just want to say hello?
        I'd love to hear from you.
      </p>
    </header>

    <div class="contact-grid">

      <!-- Contact form -->
      <section class="contact-form-section animate-on-scroll" aria-labelledby="form-heading">
        <div class="contact-form-card">
          <h2 id="form-heading">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Send a Message
          </h2>
          <p class="section-hint">
            I typically respond within 1-2 business days.
          </p>

      <form
        class="contact-form"
        action="https://formspree.io/f/xvzwwjeo"
        method="POST"
        novalidate
        id="contact-form"
      >
            <p class="contact-form-privacy">
              By sending this form, you agree to be contacted about your message.
              Your details are used only for response and are never sold.
            </p>
            <div class="form-row">
              <div class="form-group">
                <label for="name">Name <span aria-hidden="true">*</span></label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  autocomplete="name"
                  required
                  placeholder="Your full name"
                  aria-describedby="name-error"
                />
                <p id="name-error" class="field-error" aria-live="polite"></p>
              </div>

              <div class="form-group">
                <label for="email">Email <span aria-hidden="true">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  autocomplete="email"
                  required
                  placeholder="you@example.com"
                  aria-describedby="email-error"
                />
                <p id="email-error" class="field-error" aria-live="polite"></p>
              </div>
            </div>

            <div class="form-group">
              <label for="subject">Subject</label>
              <input
                type="text"
                id="subject"
                name="subject"
                placeholder="What's this about?"
                aria-describedby="subject-error"
              />
              <p id="subject-error" class="field-error" aria-live="polite"></p>
            </div>

            <div class="form-group">
              <label for="message">Message <span aria-hidden="true">*</span></label>
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                placeholder="Tell me about your project, question, or idea..."
                aria-describedby="message-error"
              ></textarea>
              <p id="message-error" class="field-error" aria-live="polite"></p>
            </div>

            <!-- Honeypot anti-spam field — hidden from real users -->
            <div class="form-group form-group--honeypot" aria-hidden="true">
              <label for="_gotcha">Leave this blank</label>
              <input type="text" id="_gotcha" name="_gotcha" tabindex="-1" autocomplete="off" />
            </div>

            <!-- Formspree: redirect back to same page after submission -->
            <input type="hidden" name="_next" value="https://andrescdo.github.io/contact/" />

            <div class="form-actions">
              <button type="submit" class="btn btn--primary btn--lg btn--wide" id="submit-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                Send Message
              </button>
              <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
            </div>
          </form>
        </div>
      </section>

      <!-- Direct contact info -->
      <aside class="contact-info animate-on-scroll" aria-labelledby="direct-heading">
        <div class="contact-info-card">
          <h2 id="direct-heading">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            Other Ways to Connect
          </h2>

          <ul class="contact-list">
            <li class="contact-item">
              <div class="contact-item__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
              </div>
              <div>
                <p class="contact-label">GitHub</p>
                <a
                  href="https://github.com/AndresCdo"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="contact-link"
                  aria-label="GitHub profile (opens in new tab)"
                >
                  github.com/AndresCdo
                </a>
              </div>
            </li>

            <li class="contact-item">
              <div class="contact-item__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              </div>
              <div>
                <p class="contact-label">LinkedIn</p>
                <a
                  href="https://www.linkedin.com/in/andres-caicedo-58888720a/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="contact-link"
                  aria-label="LinkedIn profile (opens in new tab)"
                >
                  andres-caicedo
                </a>
              </div>
            </li>

            <li class="contact-item">
              <div class="contact-item__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733 -16h-4.267zm6.4 0l9.6 16m-16 -16l9.6 16"/></svg>
              </div>
              <div>
                <p class="contact-label">Twitter / X</p>
                <a
                  href="https://twitter.com/AndresCdo"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="contact-link"
                  aria-label="Twitter profile (opens in new tab)"
                >
                  @AndresCdo
                </a>
              </div>
            </li>
          </ul>
        </div>

        <div class="availability-card">
          <div class="availability-header">
            <span class="availability-dot" aria-hidden="true"></span>
            <p class="availability-title">Open to collaboration on</p>
          </div>
          <ul class="availability-list">
            <li>CI/CD and release workflow improvements</li>
            <li>Linux operations and automation work</li>
            <li>Open-source collaboration</li>
            <li>Technical writing and knowledge sharing</li>
          </ul>
        </div>
      </aside>

    </div>
  </div>
</BaseLayout>

<script>
  // Form handling
  const form   = document.getElementById('contact-form') as HTMLFormElement | null;
  const btn    = document.getElementById('submit-btn')   as HTMLButtonElement | null;
  const status = document.getElementById('form-status')  as HTMLElement | null;

  const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function setFieldError(field: HTMLInputElement | HTMLTextAreaElement, message: string) {
    const errorEl = document.getElementById(`${field.id}-error`);
    field.classList.add('field--error');
    field.setAttribute('aria-invalid', 'true');
    if (errorEl) errorEl.textContent = message;
  }

  function clearFieldError(field: HTMLInputElement | HTMLTextAreaElement) {
    const errorEl = document.getElementById(`${field.id}-error`);
    field.classList.remove('field--error');
    field.removeAttribute('aria-invalid');
    if (errorEl) errorEl.textContent = '';
  }

  if (form && btn && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Basic client-side validation with field-level feedback
      const requiredFields = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[required]');
      requiredFields.forEach(clearFieldError);

      let valid = true;

      requiredFields.forEach((field) => {
        const value = field.value.trim();
        if (!value) {
          setFieldError(field, 'This field is required.');
          valid = false;
          return;
        }

        if (field.id === 'email' && !emailPattern.test(value)) {
          setFieldError(field, 'Please enter a valid email address.');
          valid = false;
        }
      });

      if (!valid) {
        const firstInvalidField = form.querySelector('.field--error') as HTMLElement | null;
        status.setAttribute('aria-live', 'assertive');
        status.textContent = 'Please fill in all required fields.';
        status.className   = 'form-status form-status--error';
        firstInvalidField?.focus();
        return;
      }

      btn.disabled    = true;
      btn.innerHTML   = '<svg class="spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/></svg> Sending...';
      status.textContent = '';
      status.className   = 'form-status';
      status.setAttribute('aria-live', 'polite');
      form.setAttribute('aria-busy', 'true');

      try {
        const res = await fetch(form.action, {
          method:  'POST',
          body:    new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          status.setAttribute('aria-live', 'polite');
          status.textContent = "Message sent successfully! I'll get back to you soon.";
          status.className   = 'form-status form-status--success';
          form.reset();
          requiredFields.forEach(clearFieldError);
        } else {
          const data = await res.json().catch(() => ({}));
          status.setAttribute('aria-live', 'assertive');
          status.textContent = (data as any).error ?? 'Something went wrong. Please try again.';
          status.className   = 'form-status form-status--error';
        }
      } catch {
        status.setAttribute('aria-live', 'assertive');
        status.textContent = 'Network error. Please check your connection and try again.';
        status.className   = 'form-status form-status--error';
      } finally {
        btn.disabled    = false;
        btn.innerHTML   = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Send Message';
        form.setAttribute('aria-busy', 'false');
      }
    });
  }
</script>

<style>
  .page-content { padding-block: var(--space-16); }

  .page-label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-brand);
    margin-bottom: var(--space-3);
  }

  .page-header {
    margin-bottom: var(--space-12);
    max-width: 60ch;
  }
  .page-header h1 { margin-bottom: var(--space-3); }
  .page-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  /* ── Two-column grid ── */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 3fr 2fr;
      gap: var(--space-10);
      align-items: start;
    }
  }

  /* ── Cards ── */
  .contact-form-card,
  .contact-info-card {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
  }

  .contact-form-card h2,
  .contact-info-card h2 {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
    font-size: var(--text-xl);
  }
  .section-hint {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-6);
  }

  /* ── Form ── */
  .contact-form { display: flex; flex-direction: column; gap: 0; }

  .contact-form-privacy {
    margin-bottom: var(--space-5);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }
  @media (max-width: 640px) {
    .form-row { grid-template-columns: 1fr; }
  }

  .form-group label span { color: var(--color-brand); }

  .field-error {
    min-height: 1.1rem;
    margin-top: var(--space-1);
    font-size: var(--text-xs);
    color: var(--color-error);
  }

  .form-group input.field--error,
  .form-group textarea.field--error {
    border-color: var(--color-error);
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
  }

  /* Honeypot hidden */
  .form-group--honeypot {
    position: absolute;
    left: -9999px;
    opacity: 0;
    pointer-events: none;
  }

  .form-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .btn--wide { width: 100%; justify-content: center; }

  .form-status {
    font-size: var(--text-sm);
    min-height: 1.25em;
    text-align: center;
  }
  .form-status--success { color: var(--color-success); font-weight: 600; }
  .form-status--error   { color: var(--color-error); font-weight: 600; }

  .spin {
    animation: spin-slow 1s linear infinite;
  }

  /* ── Contact list ── */
  .contact-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin-top: var(--space-6);
    margin-bottom: 0;
  }
  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }
  .contact-item__icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg);
    background: var(--color-brand-light);
    color: var(--color-brand);
    flex-shrink: 0;
  }
  .contact-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 2px;
  }
  .contact-link {
    font-size: var(--text-base);
    font-weight: 500;
  }

  /* ── Availability card ── */
  .availability-card {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    margin-top: var(--space-6);
    position: relative;
    overflow: hidden;
  }
  .availability-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient-brand);
  }

  .availability-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .availability-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-success);
    box-shadow: 0 0 8px var(--color-success);
    animation: pulse-glow 2s ease infinite;
  }

  .availability-title {
    font-weight: 600;
    font-size: var(--text-base);
    margin: 0;
  }
  .availability-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .availability-list li {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    padding-left: var(--space-5);
    position: relative;
    line-height: var(--leading-normal);
  }
  .availability-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-brand);
    opacity: 0.5;
  }
</style>
